struct Level {
    s32 length;
    char path[length];
};

bitfield Gems {
    bool blue : 1;
    bool clear : 1;
    bool green : 1;
    bool purple : 1;
    bool red : 1;
    bool yellow : 1;
};

bitfield Crystal {
    bool crystal : 1;
};

struct LevelProgression {
    Gems gems;
    Crystal crystal;
    u8 pad[2] [[hidden]];
} [[name(levelNames[std::core::array_index()])]];

struct LevelEntry {
    Level level;
    bool visited;
    u8 flags[32];
} [[name(level.path)]];

struct Levels {
    s32 count;
    LevelEntry entry[count];
} [[format("format::levels")]];

bool xboxSave = false;
struct Save {
    if ($[0x1B] == 3) {
        std::print("xbox save");
        xboxSave = true;
        u8 xboxSignature[20]; // Can be regenerated by re-signing tool
    }
    
    // PS2 stores the year as an 8-bit value (years since 2000).
    // Xbox stores the full year as a 16-bit little-endian value.
    // Both timestamp layouts occupy 7 bytes.
    // Game checks first byte to be correct against last 4 bytes of file
    if (xboxSave)
        XboxSaveTimestamp dateTime;
    else
        SaveTimestamp dateTime;
    
    Stats stats;
    Collab collab;
    Character character;
    StageData stageData;
    
    u8 unk;
    
    s32 timePlayed [[format("format::timePlayed")]];

    Level curLevel;
    s16 spawnId;
    
    float screenOffsetX;
    float screenOffsetY;
    float effectVolume;
    float musicVolume;
    
    LevelProgression levelprogress[16];
    Levels levels;
    
    // Constant and hash has to be on the correct offset for save to be valid
    if (xboxSave)
        $ = 0xF40C;
    else
        $ = 0xF3F8;
    
    u32 footerConstant;
    u32 timestampHash; // Changes depending on which day the save was made on. Game checks first byte of the file, which is the day the save was made and compares if it matches this correctly. Using zeroes here gets rid of this problem :D
};

Save save @ 0x00;