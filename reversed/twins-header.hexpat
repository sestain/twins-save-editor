import std.io;
import std.array;
import std.core;
import std.sys;
import std.string;
import std.mem;
import type.size;

namespace format {
    fn timePlayed(s32 value) {
        s32 totalSeconds = value / (150 * 60);

        s32 hours = totalSeconds / 3600;
        s32 minutes = (totalSeconds % 3600) / 60;
        s32 seconds = totalSeconds % 60;

        return std::format("{:02}:{:02}:{:02}", hours, minutes, seconds);
    };
    
    fn fixLives(s8 value) {
        return value - 1;
    };
    
    fn crystals(ref auto crystals) {
        return std::format("Crystals: {}", crystals.crystals);
    };
}

struct XboxSaveTimestamp {
    u8  day;
    u8  month;
    u16 year;
    u8  hour;
    u8  minute;
    u8  second;
    u8  constant;
};

struct SaveTimestamp {
    u8 day;
    u8 month;
    u8 year;
    u8 pad;

    u8 hour;
    u8 minute;
    u8 second;
    u8 constant;
};

