bitfield stageData {
    Stages stage : 5;
    pad : 1;
    Characters character : 4;
    signed crystals : 6;
};

bitfield headerCrystal {
    pad : 2 [[hidden]];
    signed crystals : 6;
} [[format("format::crystals")]];

struct Metadata {
    stageData stage;
    
    s8 lives [[format("format::fixLives")]];
    
    Percentages percentage;
    
    s32 timePlayed [[format("format::timePlayed")]];
    
    if (xboxSave)
        XboxSaveTimestamp timestamp;
    else
        SaveTimestamp timestamp;
        
    u32 pad;
};

bool xboxSave = false;
struct Header {
    if ($[0x1B] == 3) {
        std::print("xbox save");
        xboxSave = true;
        u8 xboxSignature[20]; // Can be regenerated by re-signing tool
    }
    
    // PS2 stores the year as an 8-bit value (years since 2000).
    // Xbox stores the full year as a 16-bit little-endian value.
    // Both timestamp layouts occupy 7 bytes.
    // Game checks first byte to be correct against last 4 bytes of file
    if (xboxSave)
        XboxSaveTimestamp timestamp;
    else
        SaveTimestamp timestamp;
    
    Metadata metadata[4];
    
    // Constant and hash has to be on the correct offset for save to be valid
    if (xboxSave)
        $ = 0x80C;
    else
        $ = 0x7F8;
    
    u32 footerConstant;
    u32 timestampHash;
};

Header header @ 0;